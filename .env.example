# Full endpoint URL of the external proxy-fetch microservice.
# The package sends requests directly to this URL and does not append a path.
PROXY_FETCH_SERVICE_URL=https://proxy-fetch-service.example/fetch

# Default timeout for LLM-oriented proxied requests, in milliseconds.
# 360000 ms = 6 minutes.
PROXY_FETCH_DEFAULT_TIMEOUT_MS=360000

# Optional API key for the external proxy-fetch microservice.
# Pass this value to createProxyFetch({ apiKey: process.env.PROXY_FETCH_SERVICE_API_KEY }).
PROXY_FETCH_SERVICE_API_KEY=
